# Choose provider: "openrouter" or "openai"
LLM_PROVIDER=openai

# OpenRouter (free tier with Gemma 4 31B)
OPENROUTER_API_KEY=SET_UR_KEY
OPENROUTER_MODEL=google/gemma-4-31b-it:free

# OpenAI (gpt-5.4-nano)
OPENAI_API_KEY=SET_UR_KEY
OPENAI_MODEL=gpt-5.4-nano

# ASR model size: tiny, base, small, medium
ASR_MODEL=tiny
